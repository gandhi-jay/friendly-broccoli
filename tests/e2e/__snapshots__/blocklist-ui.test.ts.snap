// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Blocklist UI > DOM snapshot — empty blocklist 1`] = `"<h1 class="text-2xl font-bold mb-6 text-primary">Friendly Broccoli Settings</h1><div class="flex gap-1 mb-6 bg-surface rounded-lg p-1"><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors bg-btn-bg text-primary ring-1 ring-accent">Blocklist</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">YouTube Videos</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">Quotes</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">Theme</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">Stats</button></div><div><p class="text-sm text-secondary mb-3">One pattern per line. Use <code class="text-accent code-bg px-1 rounded">*</code> as a wildcard.<br>Examples: <code class="text-accent code-bg px-1 rounded">*.reddit.com</code>, <code class="text-accent code-bg px-1 rounded">facebook.com</code>, <code class="text-accent code-bg px-1 rounded">face*.*</code></p><div class="flex gap-2 mb-4"><input class="flex-1 bg-surface border-border rounded-lg px-4 py-2 text-sm text-primary focus:border-accent focus:ring-accent" placeholder="Add a new pattern..." value=""><button class="px-4 py-2 bg-btn-bg hover:bg-btn-bg rounded-lg text-sm font-medium transition-colors text-primary ring-1 ring-accent">Add</button></div><p class="text-secondary text-sm text-center py-8">No patterns yet.</p><p class="text-secondary text-sm mt-4">0 patterns — 0 with network blocking</p></div>"`;

exports[`Blocklist UI > DOM snapshot — populated blocklist 1`] = `"<h1 class="text-2xl font-bold mb-6 text-primary">Friendly Broccoli Settings</h1><div class="flex gap-1 mb-6 bg-surface rounded-lg p-1"><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors bg-btn-bg text-primary ring-1 ring-accent">Blocklist</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">YouTube Videos</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">Quotes</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">Theme</button><button class="flex-1 px-4 py-2 rounded-md text-sm font-medium transition-colors text-secondary hover:text-primary">Stats</button></div><div><p class="text-sm text-secondary mb-3">One pattern per line. Use <code class="text-accent code-bg px-1 rounded">*</code> as a wildcard.<br>Examples: <code class="text-accent code-bg px-1 rounded">*.reddit.com</code>, <code class="text-accent code-bg px-1 rounded">facebook.com</code>, <code class="text-accent code-bg px-1 rounded">face*.*</code></p><div class="flex gap-2 mb-4"><input class="flex-1 bg-surface border-border rounded-lg px-4 py-2 text-sm text-primary focus:border-accent focus:ring-accent" placeholder="Add a new pattern..." value=""><button class="px-4 py-2 bg-btn-bg hover:bg-btn-bg rounded-lg text-sm font-medium transition-colors text-primary ring-1 ring-accent">Add</button></div><ul class="space-y-2"><li class="flex items-start gap-2 bg-surface rounded-lg px-4 py-3"><input class="flex-1 bg-transparent border-b border-transparent hover:border-border focus:border-accent text-sm text-primary outline-none py-1 transition-colors font-mono" value="*.reddit.com"><label class="flex items-center gap-1.5 shrink-0 cursor-pointer"><input class="w-3.5 h-3.5 rounded border-border bg-surface text-accent focus:ring-accent" type="checkbox"><span class="text-xs text-secondary whitespace-nowrap">Block net</span></label><button class="text-err hover:text-err text-sm font-medium shrink-0">✕</button></li><li class="flex items-start gap-2 bg-surface rounded-lg px-4 py-3"><input class="flex-1 bg-transparent border-b border-transparent hover:border-border focus:border-accent text-sm text-primary outline-none py-1 transition-colors font-mono" value="facebook.com"><label class="flex items-center gap-1.5 shrink-0 cursor-pointer"><input class="w-3.5 h-3.5 rounded border-border bg-surface text-accent focus:ring-accent" type="checkbox"><span class="text-xs text-secondary whitespace-nowrap">Block net</span></label><button class="text-err hover:text-err text-sm font-medium shrink-0">✕</button></li></ul><p class="text-secondary text-sm mt-4">2 patterns — 1 with network blocking</p></div>"`;
